---
import type { Talk } from '../data/talks';
import { svgUrl } from '../data/talks';

interface Props {
  talk: Talk;
  page: number;
}

const { talk, page } = Astro.props;
const total = talk.pageCount;
const prev = page > 1 ? `/${talk.slug}/${page - 1}` : null;
const next = page < total ? `/${talk.slug}/${page + 1}` : null;
const src = svgUrl(talk, page);
---
<div class="talk-viewer" data-slug={talk.slug} data-page={page} data-total={total}>
  <header class="talk-bar">
    <a class="talk-home" href="/" aria-label="Back to deck">← Slides</a>
    <div class="talk-meta">
      <strong>{talk.title}</strong>
      <span class="talk-counter">{page} / {total}</span>
    </div>
  </header>

  <div class="talk-stage">
    <img class="talk-slide" src={src} alt={`${talk.title} — slide ${page} of ${total}`} draggable="false" />

    {prev ? (
      <a class="talk-nav talk-prev" href={prev} aria-label="Previous slide" rel="prev">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
    ) : (
      <span class="talk-nav talk-prev disabled" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </span>
    )}

    {next ? (
      <a class="talk-nav talk-next" href={next} aria-label="Next slide" rel="next">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    ) : (
      <span class="talk-nav talk-next disabled" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </span>
    )}
  </div>

  <footer class="talk-footer">
    <div class="talk-progress" role="progressbar" aria-valuenow={page} aria-valuemin={1} aria-valuemax={total}>
      <div class="talk-progress-bar" style={`width:${(page / total) * 100}%`}></div>
    </div>
  </footer>
</div>

<script is:inline define:vars={{ slug: talk.slug, folder: talk.folder, page, total }}>
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') {
      if (page < total) { e.preventDefault(); location.href = `/${slug}/${page + 1}`; }
    } else if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
      if (page > 1) { e.preventDefault(); location.href = `/${slug}/${page - 1}`; }
    } else if (e.key === 'Home') {
      e.preventDefault(); location.href = `/${slug}/1`;
    } else if (e.key === 'End') {
      e.preventDefault(); location.href = `/${slug}/${total}`;
    } else if (e.key === 'Escape') {
      location.href = '/';
    }
  });

  // Touch swipe navigation
  const stage = document.querySelector('.talk-stage');
  if (stage) {
    let startX = 0, startY = 0, startT = 0;
    stage.addEventListener('touchstart', (e) => {
      const t = e.changedTouches[0];
      startX = t.clientX; startY = t.clientY; startT = Date.now();
    }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0];
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      const dt = Date.now() - startT;
      if (dt > 600) return;
      if (Math.abs(dx) < 40 || Math.abs(dx) < Math.abs(dy) * 1.2) return;
      if (dx < 0 && page < total) location.href = `/${slug}/${page + 1}`;
      else if (dx > 0 && page > 1) location.href = `/${slug}/${page - 1}`;
    }, { passive: true });
  }

  // Preload neighbours
  [page - 1, page + 1].forEach((n) => {
    if (n >= 1 && n <= total) {
      const img = new Image();
      img.src = `/talks/${folder}/${n}.svg`;
    }
  });
</script>
